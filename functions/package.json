{
  "name": "clarity-firebase-functions",
  "version": "1.0.0",
  "description": "Firebase Cloud Functions for Clarity expense tracking app",
  "main": "index.js",
  "engines": {
    "node": "20"
  },
  "scripts": {
    "lint": "echo 'No linting configured'",
    "serve": "firebase emulators:start --only functions",
